# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────
# Generate a secure JWT secret (min 32 chars):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
# Admin tokens expire in 8h, member tokens expire in 7d (configured in code)
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────
BACKEND_PORT=9000
NODE_ENV=development

# ── Image Base URL ────────────────────────────────────────
# Used by getFullImageUrl() to prepend to relative image paths.
# Leave empty if images are served from the same origin.
IMAGE_BASE_URL=

# ── Frontend URL (for CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:5000

# ── Upload Directory ─────────────────────────────────────
# Relative path from backend root directory
UPLOAD_DIR=./uploads
